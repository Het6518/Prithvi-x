generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  DEALER
  STAFF
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
}

enum PaymentMode {
  CASH
  UPI
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         UserRole
  createdAt    DateTime      @default(now())
  chatSessions ChatSession[]
}

model Farmer {
  id                String         @id @default(cuid())
  name              String
  village           String
  mobile            String         @unique
  cropType          String
  loyaltyTier       LoyaltyTier    @default(BRONZE)
  totalVisits       Int            @default(0)
  outstandingAmount Decimal        @default(0) @db.Decimal(12, 2)
  latitude          Float?
  longitude         Float?
  createdAt         DateTime       @default(now())
  visits            Visit[]
  creditLedger      CreditLedger?
  payments          Payment[]
}

model Visit {
  id                 String   @id @default(cuid())
  farmerId           String
  date               DateTime @default(now())
  notes              String
  recommendedProduct String?
  farmer             Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}

model Product {
  id            String         @id @default(cuid())
  name          String
  category      String
  price         Decimal        @db.Decimal(10, 2)
  stock         Int            @default(0)
  inventoryLogs InventoryLog[]
}

model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  change    Int
  date      DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id          String   @id @default(cuid())
  farmerId     String   @unique
  totalDue     Decimal  @default(0) @db.Decimal(12, 2)
  lastUpdated  DateTime @updatedAt
  farmer       Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String      @id @default(cuid())
  farmerId    String
  amount      Decimal     @db.Decimal(12, 2)
  mode        PaymentMode
  note        String?
  createdAt   DateTime    @default(now())
  farmer      Farmer      @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id           String      @id @default(cuid())
  sessionId     String
  role          MessageRole
  content       String
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
